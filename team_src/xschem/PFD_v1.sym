v {xschem version=3.4.8RC file_version=1.3}
K {type=subcircuit
format="@name @pinlist @symname"
spectre_format="@name ( @pinlist ) @symname"
template="name=x1"
}
T {@symname} -45 -6 0 0 0.3 0.3 {}
T {@name} 135 -52 0 0 0.2 0.2 {}
P 4 5 130 -40 -130 -40 -130 40 130 40 130 -40 {}
B 5 147.5 -32.5 152.5 -27.5 {name=VDD dir=inout}
L 7 130 -30 150 -30 {}
T {VDD} 125 -34 0 1 0.2 0.2 {}
B 5 147.5 -12.5 152.5 -7.5 {name=UP dir=out}
L 4 130 -10 150 -10 {}
T {UP} 125 -14 0 1 0.2 0.2 {}
B 5 -152.5 -32.5 -147.5 -27.5 {name=REF dir=in}
L 4 -150 -30 -130 -30 {}
T {REF} -125 -34 0 0 0.2 0.2 {}
B 5 147.5 7.5 152.5 12.5 {name=VSS dir=inout}
L 7 130 10 150 10 {}
T {VSS} 125 6 0 1 0.2 0.2 {}
B 5 147.5 27.5 152.5 32.5 {name=DOWN dir=out}
L 4 130 30 150 30 {}
T {DOWN} 125 26 0 1 0.2 0.2 {}
B 5 -152.5 -12.5 -147.5 -7.5 {name=FB dir=in}
L 4 -150 -10 -130 -10 {}
T {FB} -125 -14 0 0 0.2 0.2 {}
